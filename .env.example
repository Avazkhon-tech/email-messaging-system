# Copy to `.env` (used by docker-compose) and fill in real values.
# For `mvn spring-boot:run`, export these in your shell instead.

# ---- Database ----
DB_NAME=emaildb
DB_USERNAME=emailuser
DB_PASSWORD=emailpass
# Used by the app directly (overridden inside docker-compose to point at the db service):
DB_URL=jdbc:postgresql://localhost:5432/emaildb

# ---- JWT ----
# Base64-encoded 256-bit (32+ byte) signing secret.  Generate:  openssl rand -base64 48
JWT_SECRET=Y2hhbmdlLW1lLXRoaXMtaXMtYS1kZXYtb25seS1zZWNyZXQtMzJC
JWT_EXPIRATION_MS=86400000

# ---- Credential encryption ----
# Base64-encoded AES key (16/24/32 bytes decoded).  Generate:  openssl rand -base64 32
CREDENTIAL_AES_KEY=MDEyMzQ1Njc4OWFiY2RlZjAxMjM0NTY3ODlhYmNkZWY=

# ---- Mail sync scheduler ----
SYNC_INTERVAL_MS=60000
SYNC_INITIAL_DELAY_MS=15000
SYNC_FETCH_LIMIT=50

# ---- Server ----
SERVER_PORT=8080

# ---- Gmail Watch API (OAuth2 + Pub/Sub) ----
# Set GOOGLE_ENABLED=true once the OAuth client + Pub/Sub topic/subscription exist.
# When false, the "Connect Gmail" flow and Pub/Sub subscriber are disabled.
GOOGLE_ENABLED=false

# OAuth2 web client credentials (Google Cloud console > APIs & Services > Credentials).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must EXACTLY match an authorized redirect URI on the OAuth client.
GOOGLE_REDIRECT_URI=http://localhost:8080/api/oauth/google/callback
GOOGLE_SUCCESS_REDIRECT=/accounts.html

# GCP project + Pub/Sub topic/subscription that Gmail watch publishes to.
GCP_PROJECT_ID=
GMAIL_PUBSUB_TOPIC=gmail-push
GMAIL_PUBSUB_SUBSCRIPTION=gmail-push-sub

# Pub/Sub subscriber auth: put the service-account key (roles/pubsub.subscriber) at
# secrets/pubsub-sa.json. docker-compose mounts secrets/ -> /secrets and sets
# GOOGLE_APPLICATION_CREDENTIALS=/secrets/pubsub-sa.json for you. For local `mvn spring-boot:run`
# instead export it to the absolute path, e.g. $(pwd)/secrets/pubsub-sa.json.